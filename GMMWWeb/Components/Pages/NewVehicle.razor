@page "/managevehicles/new"
@using System.ComponentModel.DataAnnotations
@using System.Text
@using GMMWWeb.Data.Enums
@using GMMWWeb.Data.Records
@using GMMWWeb.Services
@using Microsoft.AspNetCore.Components.Sections
@inject VehicleService vehicleService
@inject MotoristService ownerService
@inject GMMWWeb.Data.GMMWDBContext _context
@inject NavigationManager navman

<PageTitle>Register Vehicle</PageTitle>

<h1>Register new Vehicle</h1>

<div class="createVehicle">
    <EditForm FormName="createVehicle" EditContext="editContext" OnValidSubmit="HandleVehicleSubmit">
        <DataAnnotationsValidator/>
        <ValidationSummary/>
        <div class="mb-3">
            <label for="vehicleOwner" class="form-label"><DisplayName For="@(() => newVehicle.owner)"/></label>
            <InputSelect id="vehicleOwner" class="form-select" @bind-Value="newVehicle.ownerID">
            <option selected disabled value="">[Linked Owner]</option>
            @foreach (var owner in ownerService.GetMotorists().Result)
            {
                <option value="@owner.ID">@owner.Name</option>
            }
        </InputSelect>
        </div>
        <ValidationMessage For="() => newVehicle.transmission"/>
        <div class="mb-3">
            <label for="split-plate" class="form-label">
                <DisplayName For="@(() => newVehicle.ID)"/>
            </label>
            <div id="split-plate">
                <InputText maxlength="4" oninput="this.value=this.value.toUpperCase()" @bind-Value="plateStart"
                           placeholder="AB12" class="plate-field"/>
                <ValidationMessage For="() => plateStart"/>
                <span class="dash">-</span>
                <InputText maxlength="3" oninput="this.value=this.value.toUpperCase()" @bind-Value="plateEnd"
                           placeholder="CDE" class="plate-field"/>
                <ValidationMessage For="() => plateEnd"/>
            </div>
            <ValidationMessage For="() => plateStart"/>
            <ValidationMessage For="() => plateEnd"/>
        </div>
        <div class="mb-3">
            <label for="vehicleMake" class="form-label">Make</label>
            <InputText id="vehicleMake" class="form-control" @bind-Value="newVehicle.Make"/>
            <ValidationMessage For="() => newVehicle.Make"/>
        </div>
        <div class="mb-3">
            <label for="vehicleModel" class="form-label">Model</label>
            <InputText id="vehicleModel" class="form-control" @bind-Value="newVehicle.Model"/>
            <ValidationMessage For="() => newVehicle.Model"/>
        </div>
        <div class="mb-3">
            <label for="vehicleTrans" class="form-label">Transmission</label>
            <InputSelect id="vehicleTrans" class="form-select" @bind-Value="newVehicle.transmission">
                <option selected disabled value="">[Transmission]</option>
                @foreach (var e in Enum.GetValues(typeof(Transmission)))
                {
                    <option value="@e">@e</option>
                }
            </InputSelect>
            <ValidationMessage For="() => newVehicle.transmission"/>
        </div>
        <div class="mb-3"><label for="vehicleEngine" class="form-label">Engine Type</label>
            <InputSelect id="vehicleEngine" class="form-select" @bind-Value="newVehicle.engine">
                <option selected disabled value="">[Engine Type]</option>
                @foreach (var e in Enum.GetValues(typeof(Engine)))
                {
                    <option value="@e">@e</option>
                }
            </InputSelect>
            <ValidationMessage For="() => newVehicle.engine"/>
        </div>
        <div class="mb-3"><label for="vehicleYear" class="form-label">Year</label>
            <InputNumber id="vehicleYear" class="form-control" @bind-Value="newVehicle.Year"/>
            <ValidationMessage For="() => newVehicle.Year"/>
        </div>
        <button type="submit" class="btn btn-primary" 
                disabled="@(!validField)">Register Vehicle
        </button>
    </EditForm>
</div>

@code {
    private Vehicle newVehicle = new();
    private EditContext editContext = null!;

    [Required] [RegularExpression(@"^[A-Z]{2}\d{2}$", ErrorMessage = "Registration plate must be in the format AB12-CDE")]
    protected String plateStart;

    [Required] [RegularExpression("^[A-Z]{3}$", ErrorMessage = "Registration plate must be in the format AB12-CDE")]
    protected String plateEnd;

    private bool validField;

    protected override void OnInitialized()
    {
        ResetCheck();
    }

    private String ValidPlate(string plateStart, string plateEnd)
    {
        StringBuilder sb = new();
        sb.AppendFormat($"{plateStart}-{plateEnd}");
        return sb.ToString();
    }
    
    private void ResetCheck()
    {
        newVehicle = new Vehicle();
        editContext = new EditContext(newVehicle);
        editContext.OnValidationStateChanged += (_, _) =>
        {
            validField = !editContext.GetValidationMessages().Any();
            StateHasChanged();
        };
        validField = false;
    }

    private async Task HandleVehicleSubmit()
    {
        newVehicle.ID = ValidPlate(plateStart, plateEnd);
        await vehicleService.Add(newVehicle);
        ResetCheck();
    }

}
